# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL — safe for client
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Publishable key — safe for client (RLS enforced at DB level)
# Preferred over the legacy anon key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Secret key — server only, bypasses RLS
# Needed for admin flows like webhooks, USSD, and scheduled jobs
# Never expose to client
SUPABASE_SECRET_KEY=sb_secret_...

# Optional legacy key names if your project still uses them
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Direct Postgres URL for Prisma, SQL tools, and the Supabase CLI
# Not a replacement for SUPABASE_SECRET_KEY
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ─── Paystack ────────────────────────────────────────────────────────────────
# Secret key — server only
# Use test key (sk_test_...) for development
PAYSTACK_SECRET_KEY=sk_test_...

# Public key — safe for client Paystack Inline JS
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_...

# ─── Africa's Talking ────────────────────────────────────────────────────────
# API key — server only
AFRICASTALKING_API_KEY=your_at_api_key

# Username (use "sandbox" for testing)
AFRICASTALKING_USERNAME=sandbox

# Optional: short code sender ID
AFRICASTALKING_SENDER_ID=TrustBase

# ─── Cloudinary ──────────────────────────────────────────────────────────────
# Cloud name — safe for client (used in transform URLs)
CLOUDINARY_CLOUD_NAME=your_cloud_name

# API key — server only (for signed upload URLs)
CLOUDINARY_API_KEY=your_api_key

# API secret — server only, never expose
CLOUDINARY_API_SECRET=your_api_secret

# ─── Cohere ──────────────────────────────────────────────────────────────────
# API key — server only, never expose to client
COHERE_API_KEY=your_cohere_api_key

# ─── App ─────────────────────────────────────────────────────────────────────
# Full URL (used in webhook callbacks and internal fetches)
NEXT_PUBLIC_APP_URL=http://localhost:3000
